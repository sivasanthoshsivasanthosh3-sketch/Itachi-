       <p>Athu nee mathavangala pathi romba care pani un udamba ketuthukura avanga una kashtamae paduthi irunthalum nee avangalaukaga un udamba kashtapaduthikra ...i hope nee itha korachipanu ok madam ....🫰🎂 Ok madam romba neram blade potuten poitu vanga ...one second Happy Happy Birthday lathika, izume ,princess, kullachi,muttogoes💝🫂🫴👑</p>
      </div>
      <div class="letter-sign">Forever yours, with all my heart 💕<br>Your Love 🌹</div>
      <div class="letter-deco-bottom">🎈 🎂 ⭐ 🌸 🎊 💖 🎉</div>
    </div>
    <button class="back-btn" onclick="closeLetter()">💌 Close Letter</button>
  </div>
</div>

<script>
  const emojis = ['💖','🌸','⭐','🎈','🌹','✨','🌷','🎊','💝','🌺','🎂','🌟'];
  const pCont = document.getElementById('pContainer');

  function spawnParticle() {
    const el = document.createElement('div');
    el.className = 'particle';
    el.textContent = emojis[Math.floor(Math.random() * emojis.length)];
    el.style.left = Math.random() * 100 + 'vw';
    el.style.fontSize = (14 + Math.random() * 18) + 'px';
    el.style.animationDuration = (5 + Math.random() * 6) + 's';
    el.style.animationDelay = (Math.random() * 2) + 's';
    pCont.appendChild(el);
    setTimeout(() => el.remove(), 12000);
  }

  for (let i = 0; i < 10; i++) setTimeout(spawnParticle, i * 400);
  setInterval(spawnParticle, 700);

  function launchConfetti() {
    const colors = ['#ff6fbc','#ffb347','#ffe066','#a8edea','#c3aaff','#ff4d4d','#7effd4'];
    const burst = document.getElementById('burst');
    for (let i = 0; i < 90; i++) {
      const p = document.createElement('div');
      p.className = 'cp';
      p.style.left = Math.random() * 100 + 'vw';
      p.style.width  = (8 + Math.random() * 10) + 'px';
      p.style.height = (8 + Math.random() * 10) + 'px';
      p.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
      p.style.background = colors[Math.floor(Math.random() * colors.length)];
      p.style.animationDelay    = (Math.random() * 1.2) + 's';
      p.style.animationDuration = (1.8 + Math.random() * 1.2) + 's';
      burst.appendChild(p);
      setTimeout(() => p.remove(), 3500);
    }
  }

  function openLetter() {
    document.getElementById('env').classList.add('open');
    setTimeout(() => {
      document.getElementById('envView').style.display = 'none';
      document.getElementById('letterView').style.display = 'block';
      launchConfetti();
    }, 700);
  }

  function closeLetter() {
    document.getElementById('letterView').style.display = 'none';
    document.getElementById('envView').style.display = 'block';
    document.getElementById('env').classList.remove('open');
  }
</script>
</body>
</html>
